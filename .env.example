# ── Post-purchase analytics — environment ────────────────────────────────────
# Copy to `.env.local` and fill in. NEVER commit the real values.

# Password gate for the board (the post_purchase_session cookie).
# Dev fallback is "postpurchase123" if unset — always set a real one in prod.
POST_PURCHASE_SECRET=

# ── CheckoutChamp API credentials ────────────────────────────────────────────
CHECKOUT_CHAMP_LOGIN_ID=
CHECKOUT_CHAMP_PASSWORD=
# Optional override; defaults to https://api.checkoutchamp.com
CHECKOUT_CHAMP_API_BASE=

# ── CheckoutChamp product IDs (map numeric productId → trial/sub/upsell) ──────
# Used to classify transactions. Upsell IDs are the ones that show as
# post-purchase upsells in the board. Fill in the ones you use.
CHECKOUT_CHAMP_PRODUCT_TRIAL_1_ID=
CHECKOUT_CHAMP_PRODUCT_TRIAL_5_ID=
CHECKOUT_CHAMP_PRODUCT_TRIAL_9_ID=
CHECKOUT_CHAMP_PRODUCT_TRIAL_1367_ID=
CHECKOUT_CHAMP_PRODUCT_SUB_4999_ID=
CHECKOUT_CHAMP_PRODUCT_SUB_1999_ID=
CHECKOUT_CHAMP_PRODUCT_SUB_7999_ID=
CHECKOUT_CHAMP_PRODUCT_ONETIME_15_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_PAST_LIFE_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_PURPOSE_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_CAREER_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_NETWORTH_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_KIDS_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_PLACE_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_CHAT_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_VIDEO_READING_ID=
CHECKOUT_CHAMP_PRODUCT_UPSELL_BUNDLE_ID=
CHECKOUT_CHAMP_PRODUCT_EXPEDITE_ID=
